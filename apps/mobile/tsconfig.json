{
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@brol/shared": [
        "../../packages/shared/src"
      ],
      "@brol/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@brol/api": [
        "../../packages/api/src"
      ],
      "@brol/api/*": [
        "../../packages/api/src/*"
      ]
    },
    "moduleResolution": "bundler",
    "module": "esnext",
    "jsx": "react-native"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
