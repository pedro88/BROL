{
  "name": "@brol/api",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --external:@prisma/client --external:bcryptjs",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@brol/db": "workspace:*",
    "@brol/shared": "workspace:*",
    "@trpc/server": "^11.17.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.2.8",
    "resend": "^6.12.3",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@brol/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.8"
  }
}
