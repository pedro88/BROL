// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Needed for Decimal fields (caution, rental prices)
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?  // BetterAuth: avatarUrl → image
  locale    String   @default("fr") // fr, nl, en
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth (BetterAuth uses Account.password for credentials)
  emailVerified Boolean   @default(false)
  accounts     Account[]
  sessions     Session[]

  // Relations
  collections Collection[]
  contacts    Contact[]      @relation("UserContacts")
  borrowerOf Loan[]          @relation("Borrower")
  ownerOf    Loan[]          @relation("Owner")
  borrowerOfContact Contact[] @relation("ContactBorrower")
  qrStocks   QrStock[]
  profile    Profile?
  authorReviews   Review[] @relation("ReviewAuthor")
  targetReviews   Review[] @relation("ReviewTarget")
  userBadges      UserBadge[]
  communityRequests CommunityRequest[]
  notifications   Notification[]

  @@map("users")
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  providerId           String    // BetterAuth: "credential" for email/password
  accountId            String    // BetterAuth: unique per provider
  password             String?   // BetterAuth: bcrypt/scrypt hash (set only for credential provider)
  accessToken          String?
  refreshToken         String?
  idToken              String?
  accessTokenExpiresAt DateTime? // BetterAuth (was: expiresAt Int?)
  refreshTokenExpiresAt DateTime? // BetterAuth v1.6.0
  scope                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  token        String   @unique  // BetterAuth default field name
  userId       String
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  value      String   @unique  // BetterAuth default field name
  expiresAt  DateTime

  @@unique([identifier, value])
  @@map("verification_tokens")
}

// ============================================
// COLLECTIONS & OBJECTS
// ============================================

// ObjectType: type d'objet determines which fields are relevant
enum ObjectType {
  BOOK        // Livres
  BOARD_GAME  // Jeux de société
  TOOL        // Outils manuels
  FILM        // DVD / Blu-ray
  MUSIC       // CD / Vinyl / Cassette
  ELECTRONIC  // Électronique (appareils)
  ELECTRIC    // Outillage électrique
  CLOTHING    // Vêtements / Accessoires
  CUSTOM      // Personnalisé — champs libres
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  coverImage  String?
  isPublic    Boolean  @default(false)
  // Type determines which Object fields are relevant
  type              ObjectType? @default(BOOK)
  // Labels for custom fields (only used when type = CUSTOM)
  customField1Label String?     @default("Champ libre 1")
  customField2Label String?     @default("Champ libre 2")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  objects Object[]

  @@index([userId])
  @@index([isPublic])
  @@map("collections")
}

model Object {
  id            String          @id @default(cuid())
  collectionId  String
  name          String
  author        String?
  edition       String?
  isbn          String?
  barcode       String?
  condition     ObjectCondition @default(GOOD)
  notes         String?
  coverImage    String?
  // Object type (mirrors collection.type — allows per-object override in future)
  objectType    ObjectType? @default(BOOK)
  // BOARD_GAME fields
  playersMin         Int?
  playersMax         Int?
  playingTimeMinutes Int?
  ageMin             Int?
  // ELECTRIC fields
  powerWatts Int?
  // CLOTHING fields
  clothingSize     String?  // Taille (XS, S, M, L, XL, XXL, 38, 40, 42...)
  clothingGender   String?  // Genre (Homme, Femme, Unisexe, Enfant)
  clothingColor    String?  // Couleur principale
  clothingMaterial String?  // Matière (coton, cuir, polyester...)
  // TOOL fields
  toolManual       Boolean? @default(false) // Manuel (non alimenté)
  toolSector       String?  // Secteur (construction, jardinage, automobile...)
  toolBattery      Boolean? @default(false) // Sur batterie
  // CUSTOM fields (only used when type = CUSTOM)
  customField1     String?
  customField2     String?
  // Caution et tarification
  cautionAmount    Decimal? @db.Decimal(10,2)  // Montant de la caution
  rentalPriceDay   Decimal? @db.Decimal(10,2)  // Prix location / jour
  rentalPriceHour  Decimal? @db.Decimal(10,2)  // Prix location / heure
  rentalPriceWeek  Decimal? @db.Decimal(10,2)  // Prix location / semaine
  rentalPriceKm    Decimal? @db.Decimal(10,2)  // Prix location / km
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  loans      Loan[]
  qrStock    QrStock?   @relation(fields: [qrStockId], references: [id])
  qrStockId  String?    @unique
  photos     Photo[]

  @@index([collectionId])
  @@index([isbn])
  @@map("objects")
}

model Photo {
  id        String   @id @default(cuid())
  objectId  String
  url       String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  object Object @relation(fields: [objectId], references: [id], onDelete: Cascade)

  @@index([objectId])
  @@index([objectId, position])
  @@map("photos")
}

enum ObjectCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  POOR
}

// ============================================
// CONTACTS
// ============================================

model Contact {
  id         String   @id @default(cuid())
  userId     String
  name       String
  email      String?
  phone      String?
  note       String?
  borrowerId String?  // Lien optionnel vers un User enregistré sur Brol
  createdAt  DateTime @default(now())

  user      User  @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  borrower  User? @relation("ContactBorrower", fields: [borrowerId], references: [id])
  loansAsBorrowerContact Loan[] @relation("LoanBorrowerContact")

  @@index([userId])
  @@index([email])
  @@index([borrowerId])
  @@map("contacts")
}

// ============================================
// LOANS
// ============================================

model Loan {
  id              String      @id @default(cuid())
  objectId        String
  ownerId         String
  borrowerId      String?     // User.id si le contact a un compte Brol
  borrowerContactId String?   // Contact.id si le contact n'a pas de compte
  status          LoanStatus  @default(ACTIVE)
  lentAt          DateTime    @default(now())
  returnDueDate   DateTime?
  returnedAt      DateTime?
  reminderSentAt  DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  object         Object  @relation(fields: [objectId], references: [id], onDelete: Cascade)
  owner          User    @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  borrower       User?   @relation("Borrower", fields: [borrowerId], references: [id], onDelete: Cascade)
  borrowerContact Contact? @relation("LoanBorrowerContact", fields: [borrowerContactId], references: [id], onDelete: Cascade)
  reviews         Review[] @relation("ReviewLoan")

  @@index([objectId])
  @@index([borrowerId])
  @@index([borrowerContactId])
  @@index([ownerId])
  @@index([status])
  @@index([returnDueDate])
  @@map("loans")
}

enum LoanStatus {
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

// ============================================
// USER TIER (plans d'abonnement)
// ============================================

enum UserTier {
  FREE     // 5 collections, 50 objets, 10 prêts
  TIER_2   // 10 collections, 500 objets, 50 prêts — 3€/mois
  TIER_3   // Illimité — 20€/mois
}

// ============================================
// USER PROFILE
// ============================================

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  avatarUrl String?
  tier      UserTier @default(FREE)
  tierExpiresAt DateTime? // null = jamais (ou déjà payé pour TIER_2/3)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ============================================
// REVIEWS (NOTES & COMMENTAIRES)
// ============================================

model Review {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  loanId    String   // Échange obligatoire — doit exister
  rating    Int      // 1-5 étoiles
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target User @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)
  loan   Loan @relation("ReviewLoan", fields: [loanId], references: [id], onDelete: Cascade)

  @@unique([authorId, loanId]) // Un seul review par auteur par prêt
  @@index([targetId])
  @@map("reviews")
}

// ============================================
// BADGES
// ============================================

model BadgeDefinition {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String   // Emoji ou URL vers l'icône
  criteria    Json     // Règles d'attribution automatique (ex: { "type": "loan_count", "threshold": 10 })
  createdAt   DateTime @default(now())

  userBadges UserBadge[]

  @@map("badge_definitions")
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ============================================
// COMMUNITY REQUESTS (demande à la communauté)
// ============================================

model CommunityRequest {
  id            String            @id @default(cuid())
  authorId      String
  title         String            // Titre court de ce qu'on cherche
  description   String?           // Message détaillé (optionnel)
  zone          String?           // Zone géographique (code postal, ville)
  status        RequestStatus     @default(OPEN)
  fulfillByRequestId String?       // CommunityRequest.id si une demande a été fulfill cette requête
  expiresAt     DateTime?         // Date d'expiration de la demande
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  author   User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  fulfillBy CommunityRequest? @relation("RequestFulfillment", fields: [fulfillByRequestId], references: [id], onDelete: SetNull)
  fulfilledRequests     CommunityRequest[] @relation("RequestFulfillment")

  @@index([authorId])
  @@index([status])
  @@map("community_requests")
}

enum RequestStatus {
  OPEN      // En attente
  FULFILLED // Une demande a été fulfill par un owner
  CANCELLED // Annulée par l'auteur
  EXPIRED   // Expirée
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id           String           @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  message      String?
  isRead       Boolean          @default(false)
  relatedId    String?          // ID de la ressource liée (loan, request, review...)
  relatedType  String?          // Type de ressource (loan, request, review...)
  emailSentAt  DateTime?
  createdAt    DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  RETURN_REMINDER   // Rappel de retour
  OVERDUE           // Retour en retard
  COMMUNITY_REQUEST // Nouvelle demande à la communauté
  REVIEW_RECEIVED   // Nouveau commentaire/note reçu
  REQUEST_FULFILLED // Votre demande a été traitée
}

// ============================================
// QR STOCK
// ============================================

model QrStock {
  id        String   @id @default(cuid())
  userId    String
  code      String   @unique // UUID v7 for ordering
  used      Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  objects Object[]

  @@index([userId])
  @@index([code])
  @@map("qr_stocks")
}
