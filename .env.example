# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/brol?schema=public"

# ===========================================
# AUTH (BetterAuth)
# ===========================================
# Secret for session encryption
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Apple Sign In
# clientId = Service ID from Apple Developer Portal
# teamId = Team ID from Apple Developer Account
# keyId = Key ID of the .p8 private key
# privateKey = contents of .p8 file (-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
# Pre-generated JWT client secret for web app (API server generates this dynamically)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out p256-private.pem
APPLE_CLIENT_SECRET=""
# App URL (web app only — for Apple OAuth redirect)
NEXT_PUBLIC_APPLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/apple"

# ===========================================
# STORAGE (S3 Compatible)
# ===========================================
# Hetzner Object Storage or AWS S3
S3_ENDPOINT="https://s3.eu-central-1.backblazeb2.com"
S3_REGION="eu-central-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="brol-assets"

# ===========================================
# API
# ===========================================
# API URL (for frontend)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ===========================================
# APP
# ===========================================
# Application URL (for QR codes, emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"
