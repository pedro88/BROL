# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/brol?schema=public"

# ===========================================
# AUTH (BetterAuth)
# ===========================================
# Secret for session encryption
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Apple Sign In
# clientId = Service ID from Apple Developer Portal
# teamId = Team ID from Apple Developer Account
# keyId = Key ID of the .p8 private key
# privateKey = contents of .p8 file (-----BEGIN PRIVATE KEY----- ... -----END PRIVATE KEY-----)
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
# Pre-generated JWT client secret for web app (API server generates this dynamically)
# Generate with: openssl ecparam -name prime256v1 -genkey -noout -out p256-private.pem
APPLE_CLIENT_SECRET=""
# App URL (web app only — for Apple OAuth redirect)
NEXT_PUBLIC_APPLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/apple"

# ===========================================
# STORAGE (S3 Compatible)
# ===========================================
# Hetzner Object Storage, Backblaze B2, AWS S3, MinIO, etc.
S3_ENDPOINT="https://s3.eu-central-1.backblazeb2.com"
S3_REGION="eu-central-1"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="brol-assets"

# Contraintes d'upload
S3_MAX_FILE_SIZE_MB=10
S3_ALLOWED_TYPES="image/jpeg,image/png,image/webp,image/gif"

# ===========================================
# API
# ===========================================
# API URL (for frontend)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ===========================================
# EMAIL (Resend)
# ===========================================
# Get your API key from https://resend.com
RESEND_API_KEY=""
# Sender email address (must be verified in Resend)
RESEND_FROM_EMAIL="Brol <noreply@brol.app>"

# ===========================================
# APP
# ===========================================
# Application URL (for QR codes, emails, etc.)
# - Local dev (pour scanner via téléphone sur le même réseau WiFi):
#   NEXT_PUBLIC_APP_URL="http://192.168.x.x:3000"
#   → Trouvez votre IP locale: node scripts/get-local-ip.js
# - Production:
#   NEXT_PUBLIC_APP_URL="https://brol.app"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"
